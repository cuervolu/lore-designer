{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "path:default",
    "event:default",
    "window:default",
    "webview:default",
    "app:default",
    "resources:default",
    "image:default",
    "menu:default",
    "tray:default",
    "window:allow-close",
    "window:allow-center",
    "window:allow-minimize",
    "window:allow-maximize",
    "window:allow-set-size",
    "window:allow-set-focus",
    "window:allow-start-dragging",
    "window:allow-toggle-maximize",
    "window:allow-create",
    "log:default",
    "fs:default",
    {
      "identifier": "fs:scope-appdata-recursive",
      "allow": [{ "path": "$APPDATA/*" }]
    },
    "sql:default",
    "os:default",
    "shell:default",
    "store:default",
    "dialog:default",
    "clipboard-manager:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state",
    "os:allow-arch",
    "os:allow-hostname",
    "os:allow-os-type",
    "sql:allow-load",
    "sql:allow-execute",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}