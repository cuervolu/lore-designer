{
  "name": "lore-designer-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp run @lore/desktop#dev",
    "build": "vp run -r build",
    "check": "vp run -r check",
    "test": "vp run -r test",
    "shadcn": "sh -c 'pnpm dlx shadcn@latest \"$@\" -c packages/ui' --",
    "tauri:dev": "vp run @lore/desktop#tauri:dev",
    "tauri:build": "vp run @lore/desktop#tauri:build",
    "tauri": "vp run @lore/desktop#tauri",
    "prepare": "vp config",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.50.0",
    "oxlint": "^1.67.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.22",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@11.4.0"
}
