{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@api/*": ["./src/api/*"],
      "@features/*": ["./src/features/*"],
      "@store/*": ["./src/store/*"],
      "@lore/ui": ["../../packages/ui/src/index.ts"],
      "@lore/ui/components": ["../../packages/ui/src/components"],
      "@lore/ui/components/*": ["../../packages/ui/src/components/*"],
      "@lore/ui/hooks": ["../../packages/ui/src/hooks"],
      "@lore/ui/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@lore/ui/lib": ["../../packages/ui/src/lib"],
      "@lore/ui/lib/utils": ["../../packages/ui/src/lib/utils.ts"],
      "@lore/ui/lib/*": ["../../packages/ui/src/lib/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
